# ===== BiznesOnline bot — AlwaysData env =====
# Bu fayldan nusxa oling:  cp .env.example .env  va qiymatlarni to'ldiring.
# (AlwaysData'da bu o'zgaruvchilarni "User program" sayti -> Environment bo'limiga ham qo'shing.)

# BotFather token (MAJBURIY)
BOT_TOKEN=8917607768:AAGcwl9CuafvR_TKGcE1Q-bMkK-pHEfE2jg

# Telegram /broadcast uchun admin ID lar (vergul bilan). Bo'sh bo'lsa /broadcast ishlamaydi.
ADMIN_IDS=

# HTTP server. Standart faqat localhost. Internetga ochish kerak bo'lsa: HOST=0.0.0.0
HOST=127.0.0.1
PORT=3344

# POST /bot/broadcast himoyasi (X-Admin-Token). HOST=0.0.0.0 bo'lsa ALBATTA to'ldiring.
ADMIN_TOKEN=

# Broadcast xabarlari orasidagi pauza (sekund)
BROADCAST_DELAY=0.05

# ===== Supabase (buyurtma poller) =====
# Bot Supabase'dagi yangi buyurtmalarni o'qib kanalga yuboradi — mijoz brauzeri
# bot serverga ulanishi SHART EMAS (bot faqat internetga chiqsa kifoya).
# Bu qiymatlar cloud.js bilan bir xil bo'lishi kerak. Standartlar kodда bor;
# boshqa Supabase loyiha uchun bularni o'zgartiring.
SUPABASE_URL=https://ctakvioxteagcwjlclnu.supabase.co
SUPABASE_KEY=
# Tekshirish oralig'i (sekund)
SUPABASE_POLL_SEC=12
